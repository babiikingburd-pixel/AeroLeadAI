# Copy to .env.local for local dev. In Vercel: Project Settings ->
# Environment Variables -> add for Production/Preview/Development.

# Use ONE of these two (or both — Anthropic wins automatically if both are set):

# Free, no credit card, get one at console.groq.com -> API Keys.
# Quality note: Groq's current vision model (qwen/qwen3.6-27b) is a preview
# model per Groq's own docs — good for testing the pipeline end-to-end, not
# a quality benchmark. Groq retires/renames models periodically; if damage
# scoring ever errors with "model does not exist", check
# console.groq.com/docs/vision for the current model ID and update it in
# lib/aiClient.js (two spots: callVisionModel and callTextModel).
GROQ_API_KEY=

# Better quality, pay-as-you-go, get one at console.anthropic.com -> API Keys.
# The moment this is set, every route switches to Claude automatically —
# no code changes needed, just redeploy (or restart `npm run dev` locally).
ANTHROPIC_API_KEY=

# Optional — only needed if you want real magic-link auth + Supabase sync
# instead of the password gate + localStorage fallback. See README.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional, server-side only — lets manual permit entries write to the shared
# directory even with stricter RLS. Falls back to the anon key if unset.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — enables AUTONOMOUS satellite imagery fetch by address in both the
# deep-dive console and the /batch mass-upload pipeline. Set ONE of these:
GOOGLE_MAPS_API_KEY=
MAPBOX_TOKEN=
# Map page needs this public version too (client-side Mapbox GL JS)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional — permit-history lookup (recently-permitted roofs get
# auto-deprioritized). Self-serve, no sales call required:
# Shovels.ai or PermitStack (see their docs for current pricing tiers).
PERMIT_API_KEY=
PERMIT_API_PROVIDER=

# ---- v2 upgrade additions ----
# API abuse protection: per-IP requests/min for standard routes (expensive
# AI/imagery routes have tighter built-in caps in middleware.js). Default 60.
RATE_LIMIT_PER_MIN=

# CRM sync (optional). Point these at a HubSpot workflow webhook or a
# Salesforce inbound endpoint; /api/crm-sync POSTs { leads: [...] } to them.
# CSV export works with zero setup.
HUBSPOT_WEBHOOK_URL=
SALESFORCE_WEBHOOK_URL=

# ---- Multi-Source Imagery Intelligence ----
# Automatic provider selection tries these in order: Nearmap > Google >
# Mapbox > Planet (historical) > Sentinel (historical) > Esri free fallback.
# All optional — the pipeline works with zero keys via the Esri fallback.
NEARMAP_API_KEY=
PLANET_API_KEY=
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# ---- Discovery ----
# No keys needed — city/county/polygon discovery uses the same free
# Census/Nominatim/Overpass sources as ZIP discovery.

# ---- Advanced CRM Automation (optional) ----
# Email/SMS logging works with zero setup (manual log entries). Set these to
# actually fire the send through your own provider webhook.
EMAIL_WEBHOOK_URL=
SMS_WEBHOOK_URL=

# ---- Workflow Engine (optional) ----
# Public URL of this deployment — used to build the Bland webhook callback
# URL. Set it to your real Vercel/production URL.
APP_BASE_URL=

# ---- Bland AI voice (optional) ----
# Needed for the workflow's CONTACT stage to place outbound qualify calls.
# Get BLAND_API_KEY at bland.ai, import lib/bland/pathway.json in the Bland
# dashboard (Pathways -> Import) to get BLAND_QUALIFY_PATHWAY_ID, then set a
# custom webhook secret (Pathway settings -> Webhook -> custom header
# X-Bland-Webhook-Secret) matching BLAND_WEBHOOK_SECRET below.
BLAND_API_KEY=
BLAND_QUALIFY_PATHWAY_ID=
BLAND_WEBHOOK_SECRET=

# ---- Stripe Connect payments (optional) ----
# Needed for the workflow's PAY stage. Requires a Stripe account, each
# contractor completing Connect onboarding (writes contractors.stripe_account_id),
# and a card-collection flow (Stripe Checkout/SetupIntent, not included) that
# writes jobs.stripe_customer_id / jobs.stripe_payment_method_id.
STRIPE_SECRET_KEY=
