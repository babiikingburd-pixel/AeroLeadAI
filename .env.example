# Copy to .env.local for local dev. In Vercel: Project Settings ->
# Environment Variables -> add for Production/Preview/Development.

# Use ONE of these two (or both — Anthropic wins automatically if both are set):

# Free, no credit card, get one at console.groq.com -> API Keys.
# Quality note: Groq's vision model is a "Preview" model per Groq's own
# docs — good for testing the pipeline end-to-end, not a quality benchmark.
GROQ_API_KEY=

# Better quality, pay-as-you-go, get one at console.anthropic.com -> API Keys.
# The moment this is set, every route switches to Claude automatically —
# no code changes needed, just redeploy (or restart `npm run dev` locally).
ANTHROPIC_API_KEY=

# Optional — only needed if you want real magic-link auth + Supabase sync
# instead of the password gate + localStorage fallback. See README.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional, server-side only — lets manual permit entries write to the shared
# directory even with stricter RLS. Falls back to the anon key if unset.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — enables AUTONOMOUS satellite imagery fetch by address in both the
# deep-dive console and the /batch mass-upload pipeline. Set ONE of these:
GOOGLE_MAPS_API_KEY=
MAPBOX_TOKEN=
# Map page needs this public version too (client-side Mapbox GL JS)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional — free registration at developer.usps.com. When set, the ZIP scan
# in /batch confirms/standardizes each address it finds (via OpenStreetMap)
# against USPS's own database. Note: USPS has no public API that *lists*
# every address in a ZIP — that's a separate paid CASS-licensed product —
# so this only upgrades confidence on what the OSM scan already found, it
# doesn't replace it.
USPS_CLIENT_ID=
USPS_CLIENT_SECRET=
